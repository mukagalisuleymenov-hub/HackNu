  "health_index": {
    "formula": "H = 100 - Σ(w_i × penalty_i(x_i))",
    "categories": {
      "A": { "range": [90, 100], "label": "Норма", "color": "#22c55e" },
      "B": { "range": [70, 89],  "label": "Хорошо", "color": "#84cc16" },
      "C": { "range": [50, 69],  "label": "Внимание", "color": "#eab308" },
      "D": { "range": [25, 49],  "label": "Предупреждение", "color": "#f97316" },
      "E": { "range": [0, 24],   "label": "Критично", "color": "#ef4444" }
    },
    "weights": {
      "brake_system": 0.25,
      "traction_motors": 0.20,
      "power_system": 0.20,
      "engine_thermal": 0.15,
      "speed_compliance": 0.10,
      "fuel_energy": 0.10
    },
    "penalty_function": "0 if in normal_range, linear scale to 1.0 at critical threshold"
  },

